# Server
PORT=5000
NODE_ENV=development

# Auth (required — server exits if missing)
JWT_KEY=your_jwt_secret_here

# PostgreSQL (required — server exits if missing)
# Example (Neon): postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/erb

# Set to false when connecting to local Postgres without SSL
DB_SSL=true

# Optional: enable Sequelize SQL logging
DB_LOGGING=false

# Optional: run sequelize.sync() on startup (off by default — use migration scripts instead)
DB_SYNC=false

# GL root account codes (override to match your chart of accounts)
# Hierarchy: {ROOT}.{departmentId}.{employeeCode}
ACCOUNT_CASH_BANK=1101
ACCOUNT_LOANS_ROOT=1210
ACCOUNT_PAYABLES_ROOT=2100
ACCOUNT_SALARY_EXPENSE=51001
ACCOUNT_BONUS_EXPENSE=52001
ACCOUNT_INSURANCE_EXPENSE=53001
ACCOUNT_INSURANCE_COMPANY_PAYABLE=22001
ACCOUNT_INSURANCE_EMPLOYEE_ROOT=2200
ACCOUNT_ABSENCE_REVENUE=41001

# Email (password reset flow)
EMAIL_USER=
EMAIL_PASS=
